    {
      "name": "File Transfer",
      "item": [
        {
          "name": "upload_file",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"upload_file response includes path, filename, and size\", function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.keys([\"path\", \"filename\", \"size\"]);",
                  "  pm.environment.set(\"uploaded_file_path\", body.path);",
                  "  pm.environment.set(\"uploaded_file_name\", body.filename);",
                  "  pm.environment.set(\"uploaded_file_size\", String(body.size));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/octet-stream"
              },
              {
                "key": "X-Filename",
                "value": "{{sample_upload_filename}}"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": "{{sample_upload_file_path}}"
              }
            },
            "url": {
              "raw": "{{baseUrl}}/upload_file",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "upload_file"
              ]
            },
            "description": "Upload any local file to the device as raw bytes. For IPA install, set sample_upload_file_path and sample_upload_filename, send this request, then pass uploaded_file_path to install_app. The response contains only path, filename, and size."
          }
        }
      ]
    },
